<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gas Caller Filter"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This app will automatically answer calls from numbers NOT in your contacts, turn on the speakerphone, and play your Malayalam audio message."
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btn_check_permissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable App &amp; Grant Permissions"
        android:padding="16dp" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Pending Permissions"
        android:textColor="#FF0000"
        android:layout_marginTop="32dp"
        android:textStyle="bold" />

</LinearLayout>
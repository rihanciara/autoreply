{
  "name": "lyria",
  "displayName": "Lyria Agent",
  "description": "Lyria VS Code Extension using Vertex AI (OpenCode Extension)",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lyria.start",
        "title": "Lyria: Start Agent"
      }
    ]
